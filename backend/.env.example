# ============================================
# VyaparSetu Backend - Environment Variables
# ============================================

# Server
NODE_ENV=production
PORT=5001

# Database
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/cps-store

# Auth
JWT_SECRET=your_jwt_secret_min_32_chars
JWT_REFRESH_SECRET=your_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=https://yourdomain.com/api/auth/google/callback

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Redis
REDIS_URL=redis://localhost:6379

# Email (Resend or SMTP)
RESEND_API_KEY=re_xxxx
EMAIL_FROM=noreply@yourdomain.com

# Frontend URL (for CORS and redirects)
CORS_ORIGIN=https://yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Warehouse Location
WAREHOUSE_LAT=17.094
WAREHOUSE_LNG=80.598
WAREHOUSE_PINCODE=521235
WAREHOUSE_LOCAL_RADIUS_KM=35

# Delivery Hubs (JSON array)
DELIVERY_HUBS=[{"id":"vijayawada","name":"Vijayawada Hub","lat":16.5062,"lng":80.6480,"radiusKm":60},{"id":"hyderabad","name":"Hyderabad Hub","lat":17.3850,"lng":78.4867,"radiusKm":80},{"id":"visakhapatnam","name":"Visakhapatnam Hub","lat":17.6868,"lng":83.2185,"radiusKm":70},{"id":"warangal","name":"Warangal Hub","lat":17.9784,"lng":79.5941,"radiusKm":60},{"id":"guntur","name":"Guntur Hub","lat":16.3067,"lng":80.4365,"radiusKm":50}]

# Route Configuration
ROUTE_CAPACITY_MIN=20
ROUTE_CAPACITY_MAX=30
ROUTE_MAX_DISTANCE_KM=35
ROUTE_TWO_OPT_ITERATIONS=80
ROUTE_AVG_SPEED_KMH=30
ROUTE_STOP_TIME_MIN=5
ROUTE_RECOMPUTE_DEBOUNCE_MS=300000
ROUTE_MAX_COMPUTE_MS=8000

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_key

# Sentry (optional)
SENTRY_DSN=https://xxx@sentry.io/xxx

# OTP
OTP_EXPIRY_MINUTES=10
