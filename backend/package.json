{
  "name": "cps-store-backend",
  "version": "1.0.0",
  "description": "CS Store Backend - E-commerce API",
  "main": "dist/index.js",
  "scripts": {
    "ci:check-finalizer-authority": "ts-node scripts/ci/check-finalizer-authority.ts",
    "ci:check-paymentstatus-canonical": "ts-node scripts/ci/check-paymentstatus-canonical.ts",
    "ci:check-paid-writes": "ts-node scripts/ci/check-paid-writes.ts",
    "ci:check-reservedstock-underflow": "ts-node scripts/ci/check-reservedstock-underflow.ts",
    "ci:check-paymentintent-transitions": "ts-node scripts/ci/check-paymentintent-transitions.ts",
    "ci:check-legacy-payment-lock": "ts-node scripts/ci/check-legacy-payment-lock.ts",
    "ci:check-webhook-safety": "ts-node scripts/ci/check-webhook-safety.ts",
    "ci:check-no-raw-vpa-logs": "ts-node scripts/ci/check-no-raw-vpa-logs.ts",
    "ci:check-upi-verify-safety": "ts-node scripts/ci/check-upi-verify-safety.ts",
    "ci": "npm run ci:check-finalizer-authority && npm run ci:check-paymentstatus-canonical && npm run ci:check-paid-writes && npm run ci:check-reservedstock-underflow && npm run ci:check-paymentintent-transitions && npm run ci:check-legacy-payment-lock && npm run ci:check-webhook-safety && npm run ci:check-no-raw-vpa-logs && npm run ci:check-upi-verify-safety && npm run test:ci",
    "build": "npm run ci:check-finalizer-authority && npm run ci:check-paymentstatus-canonical && npm run ci:check-paid-writes && npm run ci:check-reservedstock-underflow && npm run ci:check-paymentintent-transitions && npm run ci:check-legacy-payment-lock && npm run ci:check-webhook-safety && npm run ci:check-no-raw-vpa-logs && npm run ci:check-upi-verify-safety && tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "sh -c \"if [ '$SKIP_CI_CHECKS' = 'true' ]; then tsc -p tsconfig.json && node dist/index.js; else npm run build && node dist/index.js; fi\"",
    "dev:fast": "tsc -p tsconfig.json && NODE_ENV=development DEV_LOW_POWER=true node dist/index.js",
    "test:stress:inventory": "ts-node tests/stress/inventoryConcurrency.test.ts",
    "audit:cluster-route": "ts-node src/scripts/clusterRouteAudit.ts",
    "import-pincodes": "ts-node src/scripts/importPincodes.ts",
    "seed-pincodes": "ts-node scripts/seedPincodes.ts",
    "seed-products": "ts-node src/scripts/seedProducts.ts",
    "seed-all": "npm run seed-pincodes && npm run seed-products",
    "migrate:addresses": "ts-node src/scripts/regeocode_missing_addresses.ts",
    "migrate:products": "ts-node scripts/fixProductSchema.ts",
    "migrate:images": "ts-node scripts/migrate-images.ts",
    "fix-images": "ts-node scripts/fix-images.ts",
    "fix:delivery-availability": "ts-node scripts/fix-delivery-boy-availability.ts",
    "rebuild-images": "ts-node scripts/rebuild-images.ts",
    "delete:broken": "ts-node scripts/delete-broken-products.ts",
    "check:images": "ts-node scripts/check-images.ts",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:ci": "jest --runInBand --ci --coverage --watchAll=false --reporters=default --reporters=jest-junit",
    "test:seed": "ts-node tests/helpers/seed.ts",
    "test:reset": "ts-node tests/helpers/reset.ts",
    "test:mock": "ts-node tests/helpers/enableMocks.ts",
    "test:generate-rules": "ts-node scripts/generateRuleTests.ts",
    "test:generate-endpoints": "ts-node scripts/generateEndpointTests.ts",
    "test:property": "jest tests/property --runInBand",
    "test:property:isolated": "jest -c jest.property.config.js --runInBand",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "NODE_ENV=test jest tests/integration --runInBand --forceExit",
    "test:property": "jest tests/property --runInBand",
    "test:integration:reliability": "NODE_ENV=test OUTBOX_DISPATCHER_ENABLED_IN_TEST=true jest tests/integration/reliability.spec.ts --runInBand",
    "test:security": "jest tests/security --runInBand",
    "test:generated": "jest tests/generated --runInBand --forceExit --passWithNoTests",
    "test:security:all": "jest tests/security --runInBand --forceExit --passWithNoTests",
    "test:contracts": "jest tests/contracts --runInBand --forceExit --passWithNoTests",
    "test:security:zap": "NODE_ENV=${NODE_ENV:-test} BACKEND_URL=${BACKEND_URL:-http://localhost:5001} REPORT_PATH=test-results/security/zap-report.html bash tests/security/runZapScan.sh",
    "test:abuse": "jest tests/abuse --runInBand",
    "test:chaos": "jest tests/chaos --runInBand",
    "test:chaos:only": "jest tests/chaos --runInBand",
    "test:chaos:isolated": "jest -c jest.chaos.config.js --runInBand",
    "test:api": "SKIP_RATE_LIMIT=true newman run tests/api/postman/VyaparSetu.postman_collection.json -e tests/api/postman/local.postman_environment.json --timeout-request 30000 --delay-request 100 --reporters cli,allure --reporter-allure-export test-results/api",
    "test:e2e": "echo 'TODO: add e2e runner (e.g. Playwright/Cypress)'; exit 0",
    "test:load": "k6 run tests/load/orders-load-test.js --out json=test-results/load/load-test.json",
    "test:load:light": "k6 run --env VUS=50 --env NODE_ENV=test tests/load/orders-load-test.js --out json=test-results/load/load-test-light.json",
    "test:load:medium": "k6 run --env VUS=200 --env NODE_ENV=test tests/load/orders-load-test.js --out json=test-results/load/load-test-medium.json",
    "test:load:heavy": "k6 run --env VUS=500 --env NODE_ENV=test tests/load/orders-load-test.js --out json=test-results/load/load-test-heavy.json",
    "test:load:stress": "k6 run --env VUS=1000 --env NODE_ENV=test tests/load/orders-load-test.js --out json=test-results/load/load-test-stress.json",
    "test:auto-api": "SKIP_RATE_LIMIT=true NODE_ENV=test bash tests/api/auto/runMassSchemathesis.sh normal",
    "test:auto-api:fast": "SKIP_RATE_LIMIT=true NODE_ENV=test bash tests/api/auto/runMassSchemathesis.sh fast",
    "test:auto-api:heavy": "SKIP_RATE_LIMIT=true NODE_ENV=test bash tests/api/auto/runMassSchemathesis.sh heavy",
    "test:auto-api:extreme": "SKIP_RATE_LIMIT=true NODE_ENV=test bash tests/api/auto/runMassSchemathesis.sh extreme",
    "test:auto-api:report": "mkdir -p tests/api/auto && schemathesis run http://localhost:5001/openapi.json --checks all --max-examples=50 --workers=4 --report 'json:tests/api/auto/report.json' --report 'junit:tests/api/auto/junit-report.xml' --report-dir test-results/auto-api || schemathesis run http://localhost:5002/openapi.json --checks all --max-examples=50 --workers=4 --report 'json:tests/api/auto/report.json' --report 'junit:tests/api/auto/junit-report.xml' --report-dir test-results/auto-api",
    "test:enterprise": "npm run test:generate-rules && npm run test:generate-endpoints && npm run test:unit && npm run test:integration && jest tests/generated/rules --runInBand && jest tests/generated/endpoints --runInBand && npm run test:api && npm run test:auto-api:fast && npm run test:load:light && npm run test:security && npm run test:security:zap && npm run test:property:isolated && npm run test:chaos:isolated && npm run test:report",
    "test:all": "npm run test:unit && npm run test:integration && npm run test:security && npm run test:abuse && npm run test:chaos && npm run test:api",
    "test:ci:all": "NODE_ENV=test SKIP_RATE_LIMIT=true LOAD_TEST=true npm run test:unit && npm run test:api && npm run test:auto-api:fast",
    "test:report": "allure generate test-results --clean -o test-dashboard",
    "test:open-dashboard": "allure open test-dashboard",
    "test:dashboard": "npm run test:report && npm run test:open-dashboard",
    "lint": "eslint src --ext .ts,.tsx --fix"
  },
  "keywords": [
    "ecommerce",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@bull-board/api": "^6.20.6",
    "@bull-board/express": "^6.20.6",
    "@bull-board/ui": "^6.20.6",
    "@googlemaps/google-maps-services-js": "^3.4.2",
    "@mapbox/polyline": "^1.2.1",
    "@qdrant/js-client-rest": "^1.17.0",
    "@sentry/node": "^7.120.4",
    "@sentry/types": "^10.18.0",
    "@types/node-cache": "^4.1.3",
    "algoliasearch": "^5.45.0",
    "axios": "^1.12.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.71.1",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "csv-parser": "^3.0.0",
    "csv-writer": "^1.6.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-list-endpoints": "^7.1.1",
    "express-openapi-validator": "^5.6.2",
    "express-rate-limit": "^7.5.1",
    "express-validator": "^7.2.1",
    "google-auth-library": "^10.6.2",
    "googleapis": "^161.0.0",
    "helmet": "^7.2.0",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
    "mongodb": "^6.5.0",
    "mongoose": "^8.0.3",
    "multer": "^1.4.5-lts.1",
    "node-cache": "^5.1.2",
    "node-fetch": "^2.7.0",
    "nodemailer": "^7.0.9",
    "otp-generator": "^4.0.1",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pdfkit": "^0.15.0",
    "razorpay": "^2.9.6",
    "redis": "^4.6.10",
    "resend": "^6.1.2",
    "sharp": "^0.34.5",
    "socket.io": "^4.8.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "8.3.2"
  },
  "devDependencies": {
    "@types/algoliasearch": "^3.34.11",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-list-endpoints": "^6.0.3",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/mapbox__polyline": "^1.0.5",
    "@types/multer": "^1.4.13",
    "@types/node": "^20.10.4",
    "@types/node-fetch": "^2.6.13",
    "@types/nodemailer": "^7.0.4",
    "@types/otp-generator": "^4.0.2",
    "@types/passport": "^1.0.17",
    "@types/passport-facebook": "^3.0.3",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^3.0.13",
    "@types/pdfkit": "^0.12.12",
    "@types/supertest": "^6.0.3",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^8.3.4",
    "@typescript-eslint/eslint-plugin": "^8.46.0",
    "@typescript-eslint/parser": "^8.46.0",
    "allure-commandline": "^2.37.0",
    "eslint": "^9.37.0",
    "fast-check": "^4.5.3",
    "jest": "^29.7.0",
    "jest-allure": "^0.1.3",
    "jest-junit": "^16.0.0",
    "mongodb-memory-server": "^10.2.3",
    "nodemon": "^3.0.2",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.1",
    "typescript": "^5.3.3"
  }
}
