{
  "name": "@vyaparsetu/shared-utils",
  "version": "1.0.0",
  "description": "Shared business logic utilities for VyaparSetu web and mobile apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/delivery/index.ts src/pincode/index.ts src/timeline/index.ts src/payment/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts src/delivery/index.ts src/pincode/index.ts src/timeline/index.ts src/payment/index.ts --format cjs,esm --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./delivery": {
      "types": "./dist/delivery/index.d.ts",
      "import": "./dist/delivery/index.mjs",
      "require": "./dist/delivery/index.js"
    },
    "./pincode": {
      "types": "./dist/pincode/index.d.ts",
      "import": "./dist/pincode/index.mjs",
      "require": "./dist/pincode/index.js"
    },
    "./timeline": {
      "types": "./dist/timeline/index.d.ts",
      "import": "./dist/timeline/index.mjs",
      "require": "./dist/timeline/index.js"
    },
    "./payment": {
      "types": "./dist/payment/index.d.ts",
      "import": "./dist/payment/index.mjs",
      "require": "./dist/payment/index.js"
    }
  },
  "keywords": [
    "vyaparsetu",
    "shared",
    "utils",
    "ecommerce"
  ],
  "author": "VyaparSetu Team",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.3.0"
  }
}
