{
  "name": "cps-store-frontend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run ci:check-polling-discipline && npm run check:translations && tsc && vite build",
    "check:translations": "npx ts-node --esm scripts/check-translations.ts",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "ci:check-polling-discipline": "node scripts/ci/check-frontend-polling-discipline.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:logic": "vitest run --coverage --pool=threads",
    "test:fast": "vitest --pool=threads",
    "e2e": "playwright test --workers=4 --retries=2 --reporter=html",
    "test:unit": "vitest",
    "test:unit:run": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:ci": "playwright test --reporter=junit",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:safari": "playwright test --project=webkit",
    "test:e2e:mobile": "playwright test --project='Mobile Chrome'",
    "test:e2e:smoke": "playwright test --grep=@smoke",
    "test:e2e:regression": "playwright test --grep=@regression",
    "test:e2e:visual": "playwright test --grep=@visual",
    "test:e2e:install": "playwright install",
    "test:e2e:report": "playwright show-report",
    "test:e2e:codegen": "playwright codegen"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "1.16.2",
    "@reduxjs/toolkit": "^2.11.2",
    "@sentry/react": "^7.120.4",
    "@tanstack/react-virtual": "^3.0.0",
    "@vyaparsetu/shared-utils": "*",
    "async-mutex": "^0.5.0",
    "browser-image-compression": "^2.0.2",
    "cloudinary": "^2.8.0",
    "esbuild": "^0.27.3",
    "framer-motion": "10.16.4",
    "lucide-react": "^0.545.0",
    "qrcode.react": "^4.2.0",
    "razorpay": "^2.9.6",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-hot-toast": "2.4.1",
    "react-is": "^19.2.3",
    "react-redux": "^9.2.0",
    "react-router-dom": "^6.30.3",
    "recharts": "2.5.0",
    "socket.io-client": "^4.6.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "20.4.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.1",
    "autoprefixer": "10.4.19",
    "jsdom": "^27.0.1",
    "postcss": "8.4.38",
    "tailwindcss": "3.4.3",
    "typescript": "5.1.6",
    "vite": "^6.4.1",
    "vite-plugin-compression2": "^2.5.1",
    "vitest": "^1.6.1",
    "wait-on": "^9.0.4"
  }
}
