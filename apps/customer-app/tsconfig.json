{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": false,
    "skipLibCheck": true,
    "noEmit": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["jest", "@testing-library/react-native"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@vyaparsetu/types": ["../../packages/types/src"],
      "@vyaparsetu/shared-utils": ["../../packages/shared-utils/src"],
      "@vyaparsetu/i18n": ["../../packages/i18n/src"]
    }
  }
}
