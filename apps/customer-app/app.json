{
  "expo": {
    "name": "VyaparSetu",
    "slug": "vyaparsetu-customer",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E95C1E"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vyaparsetu.customer"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E95C1E"
      },
      "package": "com.vyaparsetu.customer",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      [
        "expo-notifications",
        {
          "color": "#E95C1E"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
