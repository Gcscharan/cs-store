{
  "expo": {
    "name": "VyaparSetu",
    "slug": "vyaparsetu-monorepo",
    "scheme": "vyaparsetu-customer",
    "version": "1.0.0",
    "platforms": [
      "android",
      "ios"
    ],
    "android": {
      "package": "com.vyaparsetu.customer",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBNKtlvo5xWWO-S02fm1GCIr6eVLJmFP_k"
        }
      },
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#f97316"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "ios": {
      "bundleIdentifier": "com.vyaparsetu.customer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to track deliveries and navigate to customer addresses.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "We need your location to track deliveries and navigate to customer addresses.",
        "NSLocationAlwaysUsageDescription": "We need your location to track deliveries while in the background.",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location for delivery tracking.",
          "isAndroidBackgroundLocationEnabled": true
        }
      ],
      "expo-web-browser",
      "@react-native-google-signin/google-signin",
      "expo-image",
      "expo-speech-recognition"
    ],
    "extra": {
      "eas": {
        "projectId": "4fdb021f-e1f7-420f-a095-dd646ee20186"
      }
    }
  }
}
